func recurse(depth: i32) -> i32 {
    a: *i32 = new i32(depth);
    print_i32(*a);
    print_newline();

    if (depth <= 0) {
        return *a;
    }

    {
        b: *i32 = new i32(depth * 10);
        c: **i32 = new *i32(b);

        print_i32(**c);
        print_newline();

        if (depth % 2 == 0) {
            d: ***i32 = new **i32(c);
            print_i32(***d);
            print_newline();
            return ***d;     // early return deep in nesting
        }
    }

    e: *i32 = new i32(depth * 100);
    print_i32(*e);
    print_newline();

    return recurse(depth - 1) + *e;
}

func main() -> i32 {
    total: i32 = 0;

    i: i32 = 0;
    while (i < 20) {

        outer: *i32 = new i32(i);
        print_i32(*outer);
        print_newline();

        {
            shadow: *i32 = new i32(i * 1000);
            print_i32(*shadow);
            print_newline();

            if (i % 3 == 0) {
                nested: **i32 = new *i32(shadow);
                print_i32(**nested);
                print_newline();
                total = total + **nested;
            } else {
                total = total + recurse(i % 5);
            }
        }

        // overwrite outer (tests drop-before-reassign)
        outer = new i32(i * 7);
        print_i32(*outer);
        print_newline();

        total = total + *outer;

        i = i + 1;
    }

    print_i32(total);
    print_newline();
    
    return total;
}