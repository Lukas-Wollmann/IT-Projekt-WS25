struct Pair {
    a: i32,
    b: i32
}

func mk_pair(x: i32, y: i32) -> Pair {
    return Pair { x, y };
}

func sum_pair(p: Pair) -> i32 {
    return p.a + p.b;
}

func bump_pair(p: Pair, n: i32) -> Pair {
    i: i32 = 0;
    r: Pair = p;

    while (i < n) {
        r.a = r.a + 1;
        r.b = r.b + 1;
        i = i + 1;
    }

    return r;
}

func fold_seed(limit: i32) -> i32 {
    i: i32 = 0;
    acc: i32 = 0;

    while (i < limit) {
        if ((i % 2) == 0) {
            acc = acc + i;
        } else {
            acc = acc - i;
        }
        i = i + 1;
    }

    return acc;
}

func step_0(x: i32) -> i32 {
    p: Pair = mk_pair(x + 0, x - 0);
    q: Pair = bump_pair(p, (0 % 7) + 1);
    v: i32 = sum_pair(q);

    if ((v % 3) == 0) {
        return v + fold_seed((0 % 11) + 3);
    }

    return v - fold_seed((0 % 5) + 2);
}

func step_1(x: i32) -> i32 {
    p: Pair = mk_pair(x + 1, x - 1);
    q: Pair = bump_pair(p, (1 % 7) + 1);
    v: i32 = sum_pair(q);

    if ((v % 3) == 0) {
        return v + fold_seed((1 % 11) + 3);
    }

    return v - fold_seed((1 % 5) + 2);
