func main() -> i32 {
    x: i32 = 1;
    i: i32 = 0;

    while (i < 1500) {
        x = step_0(x);
        x = step_1(x);
        x = step_2(x);
        x = step_3(x);
        x = step_4(x);
        x = step_5(x);
        x = step_6(x);
        x = step_7(x);
        x = step_8(x);
        x = step_9(x);

        if ((i % 4) == 0) {
            x = x + i;
        } else {
            x = x - i;
        }

        i = i + 1;
    }

    print_i32(x);
    print_newline();
    return 0;
}
