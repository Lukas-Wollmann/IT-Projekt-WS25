{
  "name": "C++ Dev Container (Ubuntu 24.04)",
  "build": {
    "dockerfile": "../Dockerfile"
  },

  "workspaceFolder": "/workspace",

  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind"
  ],

  "customizations": {
    "vscode": {
        "extensions": [
            "ms-vscode.cpptools-extension-pack",
            "ms-vscode.hexeditor",
            "gruntfuggly.todo-tree"
        ]
    }
  },

  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt",
    "seccomp=unconfined"
  ]
}
