func print_i32_array(a: []i32) {
    if (a == null) {
        print_char('x');
        return;
    }

    
    i: i32 = 0;
    
    while (i < len(a)) {
        print_i32(a[i]);
        print_char(' ');
        i += 1;
    }
}

func main() -> i32 {
    
    a: [][]i32 = new[10] []i32;
    i: i32 = 0;


    while (i < len(a)) {
        a[i] = new[i + 1] i32;
        a[i][0] = i;

        print_i32_array(a[i]);
        print_newline();
        
        i += 1;
    }


    return 0;
}